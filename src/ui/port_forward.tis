// Connection state constants
var PF_STATE_INITIALIZING = "initializing";
var PF_STATE_WAITING = "waiting";
var PF_STATE_CONNECTED = "connected";
var PF_STATE_ERROR = "error";

// Global connection state for port forward / RDP
var pf_conn_state = PF_STATE_INITIALIZING;
var pf_conn_error = "";
var pf_conn_start_time = null;
var pf_duration_timer = null;

// Per-tunnel status: port -> { state: "listening"|"connected"|"error", error: "" }
var pf_tunnel_status = {};

function formatDuration(ms) {
    var secs = (ms / 1000).toInteger();
    var h = (secs / 3600).toInteger();
    var m = ((secs % 3600) / 60).toInteger();
    var s = secs % 60;
    if (h > 0) return String.printf("%d:%02d:%02d", h, m, s);
    return String.printf("%02d:%02d", m, s);
}

class PortForward: Reactor.Component {
    this var settingsExpanded = false;
    this var rdpPort = "";
    this var rdpUsername = "";
    this var rdpPassword = "";

    function this(params) {
        if (handler.is_rdp()) {
            this.rdpPort = handler.get_option("rdp_port") || "";
            this.rdpUsername = handler.get_option("rdp_username") || "";
            this.rdpPassword = handler.get_option("rdp_password") || "";
        }
    }

    function render() {
        var args = handler.get_args();
        var is_rdp = handler.is_rdp();

        if (is_rdp) {
            return this.renderRdp();
        }

        // --- Generic Port Forward (unchanged logic) ---
        if (args.length) {
            this.pfs = [args];
        } else {
            this.pfs = handler.get_port_forwards();
        }
        var pfs = this.pfs.map(function(pf, i) {
            var status = pf_tunnel_status[pf[0]] || { state: "listening", error: "" };
            var dot_class = "pf-status-dot " + status.state;
            var dot_title = status.state == "error" ? status.error : translate(status.state);
            return <tr key={i} .value>
                {args.length ? "" : <td .status-cell><div class={dot_class} title={dot_title} /></td>}
                <td>{pf[0]}</td>
                <td .right-arrow style="text-align: center; padding-left: 0">{args.length ? svg_arrow : ""}</td>
                <td>{pf[1] || "localhost"}</td>
                <td>{pf[2]}</td>
                {args.length ? "" : <td .remove>{svg_cancel}</td>}
            </tr>;
        });
        return <div #file-transfer><section>
            {pfs.length ? <div style="background: green; color: white; text-align: center; padding: 0.5em;">
                <span style="font-size: 1.2em">{translate('Listening ...')}</span><br/>
                <span style="font-size: 0.8em; color: #ddd">{translate('not_close_tcp_tip')}</span>
            </div> : ""}
            <table #port-forward>
            <thead>
                <tr>
                    {args.length ? "" : <th style="width: 3em">{translate('Status')}</th>}
                    <th>{translate('Local Port')}</th>
                    <th style="width: 1em" />
                    <th>{translate('Remote Host')}</th>
                    <th>{translate('Remote Port')}</th>
                    {args.length ? "" : <th style="width: 6em">{translate('Action')}</th>}
                </tr>
            </thead>
            <tbody key={pfs.length}>
                {args.length ? "" :
                <tr>
                    <td />
                    <td><input|number #port /></td>
                    <td .right-arrow style="text-align: center">{svg_arrow}</td>
                    <td><input|text #remote-host novalue="localhost" /></td>
                    <td><input|number #remote-port /></td>
                    <td style="margin:0;"><button .button #add title={translate('Add')}>{translate('Add')}</button></td>
                </tr>
                }
                {pfs}
            </tbody>
            </table></section></div>;
    }

    function renderRdp() {
        var peer_id = handler.get_id();
        var pi = handler.get_default_pi();
        var peer_name = (pi && pi.hostname) ? pi.hostname : peer_id;

        var state = pf_conn_state;
        var duration_text = "";
        if (state == PF_STATE_CONNECTED && pf_conn_start_time) {
            duration_text = formatDuration(Date.now() - pf_conn_start_time);
        }

        var rdp_port_display = this.rdpPort || "3389";

        return <div #file-transfer .rdp-mode>
            {this.renderStatusBar(state, peer_name, duration_text)}
            <div .rdp-toolbar>
                <div .rdp-toolbar-info>
                    <div .rdp-info-row>
                        <span .rdp-label>{translate("Remote Host")}:</span>
                        <span .rdp-value>localhost:{rdp_port_display}</span>
                        <span .rdp-via>{translate("via")} {translate("Tunnel")}</span>
                    </div>
                </div>
                <div .rdp-toolbar-actions>
                    <button .button #new-rdp>{translate("New RDP")}</button>
                </div>
            </div>
            {this.renderSettings()}
        </div>;
    }

    function renderStatusBar(state, peer_name, duration_text) {
        var status_class = "rdp-status " + state;
        var icon = "";
        var text = "";
        var subtext = "";

        if (state == PF_STATE_INITIALIZING) {
            icon = <div .rdp-status-spinner />;
            text = translate("Initializing") + "...";
            subtext = translate("not_close_tcp_tip");
        } else if (state == PF_STATE_WAITING) {
            icon = <div .rdp-status-dot .waiting />;
            text = translate("Waiting for RDP client");
            subtext = translate("not_close_tcp_tip");
        } else if (state == PF_STATE_CONNECTED) {
            icon = <div .rdp-status-dot .connected />;
            text = translate("Connected to") + " " + peer_name;
            subtext = duration_text;
        } else if (state == PF_STATE_ERROR) {
            icon = <div .rdp-status-dot .error />;
            text = pf_conn_error || translate("Connection failed");
            subtext = "";
        }

        return <div class={status_class}>
            <div .rdp-status-left>
                {icon}
                <div .rdp-status-text>
                    <span .rdp-status-main>{text}</span>
                    {subtext ? <span .rdp-status-sub>{subtext}</span> : ""}
                </div>
            </div>
        </div>;
    }

    function renderSettings() {
        var expanded = this.settingsExpanded;
        var toggle_icon = expanded ? "?" : "?";
        return <div .rdp-settings>
            <div .rdp-settings-header #toggle-settings>
                <span>{translate("Settings")}</span>
                <span .rdp-settings-toggle>{toggle_icon}</span>
            </div>
            {expanded ? <div .rdp-settings-body>
                <div .rdp-settings-row>
                    <label>{translate("Port")}:</label>
                    <input|text #rdp-port value={this.rdpPort} novalue="3389" />
                </div>
                <div .rdp-settings-row>
                    <label>{translate("Username")}:</label>
                    <input|text #rdp-username value={this.rdpUsername} />
                </div>
                <div .rdp-settings-row>
                    <label>{translate("Password")}:</label>
                    <PasswordComponent value={this.rdpPassword} name="rdp-password" />
                </div>
                <div .rdp-settings-actions>
                    <button .button #save-rdp-settings>{translate("Save")}</button>
                </div>
            </div> : ""}
        </div>;
    }

    // --- Event handlers ---

    event click $(#add) () {
        var port = ($(#port).value || "").toInteger() || 0;
        var remote_host = $(#remote-host).value || "";
        var remote_port = ($(#remote-port).value || "").toInteger() || 0;
        if (port <= 0 && remote_port <= 0) {
            handler.msgbox("custom-nocancel-nook-hasclose", "", translate("Please enter local and remote port numbers"), "");
            return;
        }
        if (port <= 0) {
            handler.msgbox("custom-nocancel-nook-hasclose", "", translate("Please enter a local port number"), "");
            return;
        }
        if (remote_port <= 0) {
            handler.msgbox("custom-nocancel-nook-hasclose", "", translate("Please enter a remote port number"), "");
            return;
        }
        handler.add_port_forward(port, remote_host, remote_port);
        this.update();
    }

    event click $(#new-rdp) {
        handler.new_rdp();
    }

    event click $(.remove svg) (_, me) {
        var pf = this.pfs[me.parent.parent.index - 1];
        delete pf_tunnel_status[pf[0]];
        handler.remove_port_forward(pf[0]);
        this.update();
    }

    event click $(#toggle-settings) {
        this.settingsExpanded = !this.settingsExpanded;
        this.update();
    }

    event click $(#save-rdp-settings) {
        var port = ($(#rdp-port).value || "").trim();
        var username = ($(#rdp-username).value || "").trim();
        var pass_el = this.$([name="rdp-password"]);
        var password = pass_el ? (pass_el.value || "").trim() : "";

        handler.set_option("rdp_port", port);
        handler.set_option("rdp_username", username);
        handler.set_option("rdp_password", password);

        this.rdpPort = port;
        this.rdpUsername = username;
        this.rdpPassword = password;

        this.update();
    }
}

function setPfState(state, error = "") {
    pf_conn_state = state;
    if (error.length > 0) pf_conn_error = error;
    if (state == PF_STATE_CONNECTED && !pf_conn_start_time) {
        pf_conn_start_time = Date.now();
    }
    if (state == PF_STATE_ERROR || state == PF_STATE_INITIALIZING) {
        pf_conn_start_time = null;
    }
    var el = $(#file-transfer);
    if (el && el.parent) {
        el.parent.content(<PortForward />);
    }
}

function initializePortForward()
{
    $(#file-transfer-wrapper).content(<PortForward />);
    $(#video-wrapper).style.set { visibility: "hidden", position: "absolute" };
    $(#file-transfer-wrapper).style.set { display: "block" };

    var is_rdp = handler.is_rdp();
    if (is_rdp) {
        // Set initial state
        setPfState(PF_STATE_INITIALIZING);

        // Transition to "waiting" after a short delay (tunnel listener is starting)
        self.timer(1500ms, function() {
            if (pf_conn_state == PF_STATE_INITIALIZING) {
                setPfState(PF_STATE_WAITING);
            }
        });

        // Start duration update timer
        pf_duration_timer = self.timer(1000ms, function() {
            if (pf_conn_state == PF_STATE_CONNECTED) {
                var el = $(#file-transfer);
                if (el && el.parent) {
                    el.parent.content(<PortForward />);
                }
            }
            return true; // keep timer repeating
        });
    }

    // Hook into updatePi to detect successful connection
    var origUpdatePi = handler.updatePi;
    handler.updatePi = function(v) {
        if (is_rdp && (pf_conn_state == PF_STATE_INITIALIZING || pf_conn_state == PF_STATE_WAITING || pf_conn_state == PF_STATE_ERROR)) {
            setPfState(PF_STATE_CONNECTED);
        }
        // Call original handler (header update, minimize, etc.)
        if (origUpdatePi) origUpdatePi.call(handler, v);
    };

    // Hook into msgbox_retry to capture errors and per-tunnel status
    var origMsgboxRetry = handler.msgbox_retry;
    handler.msgbox_retry = function(type, title, text, link, hasRetry) {
        // Intercept port-forward-status info messages (connected notification)
        if (type == "info" && title == "port-forward-status") {
            var match = text.match(/\[port:(\d+)\]/);
            if (match) {
                var port = match[1].toInteger();
                pf_tunnel_status[port] = { state: "connected", error: "" };
                var el = $(#file-transfer);
                if (el && el.parent) el.parent.content(<PortForward />);
            }
            return; // don't show a visible msgbox
        }

        // Intercept port-tagged errors for per-tunnel status
        if (type == "error") {
            var match = text.match(/\[port:(\d+)\]\s*(.*)/);
            if (match) {
                var port = match[1].toInteger();
                var errorText = match[2];
                pf_tunnel_status[port] = { state: "error", error: errorText };
                var el = $(#file-transfer);
                if (el && el.parent) el.parent.content(<PortForward />);
                return; // show status dot instead of popup
            }
        }

        if (is_rdp && type == "error") {
            setPfState(PF_STATE_ERROR, text);
        }
        if (origMsgboxRetry) origMsgboxRetry.call(handler, type, title, text, link, hasRetry);
    };
}
