class PasswordComponent: Reactor.Component {
    this var visible = false;
    this var value = '';
    this var name = 'password';

    function this(params) {
      if (params && params.value) {
          this.value = params.value;
      }
      if (params && params.name) {
          this.name = params.name;
      }
    }

    function render() {
        return <div .password>
            <input name={this.name} value={this.value} type={this.visible ? "text" : "password"} title={translate("Password")} .outline-focus />
            {this.visible ? svg_eye_cross : svg_eye}
        </div>;
    }

    event click $(svg) {
        var el = this.$(input);
        var value = el.value;
        var start = el.xcall(#selectionStart) || 0;
        var end = el.xcall(#selectionEnd);
        this.update({ visible: !this.visible });
        var me = this;
        self.timer(30ms, function() {
            var el = me.$(input);
            view.focus = el;
            el.value = value;
            el.xcall(#setSelection, start, end);
        });
    }
}

// type: #post, #get, #delete, #put
function httpGetRequest(url, type, params, _onSuccess, _onError, headers="") {
    if (type != #get) {
        stderr.println("only get ok");
    }
    handler.get_request(url, headers);
    function check_status() {
        var status = handler.get_async_job_status();
        if (status == " ") self.timer(0.1s, check_status);
        else {
            try {
                var data = JSON.parse(status);
                _onSuccess(data);
            } catch (e) {
                _onError(status, 0);
            }
        }
    }
    check_status();
}

function isReasonableSize(r) {
    var x = r[0];
    var y = r[1];
    var n = scaleIt(3200);
    return !(x < -n || x > n || y < -n || y > n);
}

function awake() {
    view.windowState = View.WINDOW_SHOWN;
    view.focus = self;
}

class MultipleSessionComponent extends Reactor.Component {
    this var sessions = [];
    this var messageText = translate("Please select the session you want to connect to");

    function this(params) {
        if (params && params.sessions) {
            this.sessions = params.sessions;
        }
    }

    function render() {
        return <div .user-session>
            <div .title>{this.messageText}</div>
            <select>
                {this.sessions.map(session =>
                    <option value={session.sid}>{session.name}</option>
                )}
            </select>
        </div>;
    }
}

/******************** start of popup menu overlay ************************/
// Sciter's native <popup> is broken on macOS ARM64 and on Windows DirectDraw
// paints over native popup HWNDs. Use in-window overlay with position:fixed.
// Sciter's position:fixed does NOT escape overflow ancestors, so we temporarily
// override overflow on clipping ancestors while the popup is shown.
var _activePopup = null;
var _overflowOverrides = [];

function showPopupMenu(anchor, menu) {
    closePopupMenu();
    if (!menu) return;

    _activePopup = menu;

    var (ax, ay, aw, ah) = anchor.box(#rectw, #border, #view);

    // Walk ancestors and temporarily set overflow:visible on any that clip.
    _overflowOverrides = [];
    var el = menu.parent;
    while (el && el.tag != "body") {
        var ov = el.style#overflow;
        var ovx = el.style#overflow-x;
        var ovy = el.style#overflow-y;
        if (ov == "hidden" || ov == "auto" || ov == "scroll" ||
            ovx == "hidden" || ovx == "auto" || ovx == "scroll" ||
            ovy == "hidden" || ovy == "auto" || ovy == "scroll") {
            _overflowOverrides.push(el);
            el.style.set {
                overflow: "visible",
                "overflow-x": "visible",
                "overflow-y": "visible",
            };
        }
        el = el.parent;
    }

    menu.attributes.addClass("osx-popup-active");
    menu.style.set { visibility: "hidden" };

    var mw = menu.box(#width, #border);
    var mh = menu.box(#height, #border);
    var vw = $(body).box(#width, #border);
    var vh = $(body).box(#height, #border);

    var left = ax;
    var top = ay + ah + 2;
    if (left + mw > vw) left = vw - mw - 4;
    if (left < 0) left = 0;
    if (top + mh > vh) top = ay - mh - 2;
    if (top < 0) top = 0;

    $(body).$append(<div .osx-popup-backdrop />);
    var backdrop = $(body).$(.osx-popup-backdrop);
    if (backdrop) {
        backdrop.on("mousedown", function() {
            closePopupMenu();
            return true;
        });
    }

    menu.style.set {
        visibility: "visible",
        left: left + "px",
        top: top + "px",
    };
}

function closePopupMenu() {
    var backdrop = $(.osx-popup-backdrop);
    if (backdrop) try { backdrop.detach(); } catch(e) {}
    if (_activePopup) {
        try {
            _activePopup.attributes.removeClass("osx-popup-active");
            _activePopup.style.set {
                visibility: undefined,
                left: undefined,
                top: undefined,
            };
        } catch(e) {}
        _activePopup = null;
    }
    for (var el in _overflowOverrides) {
        try {
            el.style.set {
                overflow: undefined,
                "overflow-x": undefined,
                "overflow-y": undefined,
            };
        } catch(e) {}
    }
    _overflowOverrides = [];
    if (typeof updateWindowToolbarPosition == "function") updateWindowToolbarPosition();
}

// Auto-close popup when a menu item is clicked
self.on("click", "menu.context.osx-popup-active li", function() {
    self.timer(1ms, closePopupMenu);
});
/******************** end of popup menu overlay *****************************/