> \
			<span style=\"margin-top: 5px; margin-bottom: 15px;\">" + translate("An update is available, do you want to update to the new version?") + "</span><br></br> \
				<div style=\"margin-top: 30px; display: flex; align-items: center; \"> \
					<div id='dontshowagain' .custom-event style=\"float:left; width: 20px; height: 20px; border: 4px solid #2196F3; border-radius: 8px; cursor: pointer;\"> \
						<div id='dontshowagainchecked'></div> \
					</div> \
					<div style=\"height:32px; vertical-align: middle; \"><div style=\"margin-left: 40px; display:block; \">" + translate("Don't show this again.") + "</div></div> \
				</div> \
			<br></br> \
			", "", function(el) {
				if (el) {
					if (el.type === "custom-nocancel-nook-hasyes-hasno"){
						if ($(#dontshowagainchecked).attributes.hasClass("checkboxunchecked")) {
							showingupdate = "";
						}
										
						view.windowState = View.WINDOW_MINIMIZED;
						handler.run_temp_update();
						
						if ($(#dontshowagainchecked).attributes.hasClass("checkboxchecked")) {
							showingupdate = "";
						}				
						
						return;						
					}
					if (el.id === 'dontshowagain') {
						if ($(#dontshowagain).attributes.hasClass("checkedtrue")) {
							$(#dontshowagain).attributes.removeClass("checkedtrue");
							$(#dontshowagain).html = '';
							handler.set_local_option("dontshowagain", "");
						} else {
							$(#dontshowagain).html = '<div id="dontshowagainchecked" style="margin-top: -7px; margin-left: 2px;  font-weight: 900; font-size: 25px; color: #2196F3; cursor: pointer; ">&#10003;</div>';
							$(#dontshowagain).attributes.addClass("checkedtrue");
							handler.set_local_option("dontshowagain", "1");
						}
					}
                } {
					showingupdate = "";
				}
				
            }, 240);
    }	

    function handleMenuClick(me) {
        if (me.id && me.id.indexOf("enable-") == 0) {
            handler.set_option(me.id, handler.get_option(me.id) == "N" ? "" : "N");
        }
        if (me.id && me.id.indexOf("allow-") == 0) {
            handler.set_option(me.id, handler.get_option(me.id) == "Y" ? "" : "Y");
        }
        if (me.id == "whitelist") {
            var old_value = handler.get_option("whitelist").split(",").join("\n");
            msgbox("custom-whitelist", translate("IP Whitelisting"), "<div .form> \
            <div>" + translate("whitelist_sep") + "</div> \
            <textarea spellcheck=\"false\" name=\"text\" novalue=\"0.0.0.0\" style=\"overflow: scroll-indicator; width:*; height: 140px; font-size: 1.2em; padding: 0.5em; margin-bottom: 10px; \">" + old_value + "</textarea>\
            </div> \
            ", "", function(res=null) {
                if (!res) return;
				var value = (res.text || "").trim();
                if (value) {
                    var values = value.split(/[\s,;\n]+/g);
                    for (var ip in values) {
                        if (!ip.match(/^(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]?|0)\.(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]?|0)\.(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]?|0)\.(25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]?|0)(\/([1-9]|[1-2][0-9]|3[0-2])){0,1}$/)
                            && !ip.match(/^(((?:[0-9A-Fa-f]{1,4}))*((?::[0-9A-Fa-f]{1,4}))*::((?:[0-9A-Fa-f]{1,4}))*((?::[0-9A-Fa-f]{1,4}))*|((?:[0-9A-Fa-f]{1,4}))((?::[0-9A-Fa-f]{1,4})){7})(\/([1-9]|[1-9][0-9]|1[0-1][0-9]|12[0-8])){0,1}$/)) {
                            return translate("Invalid IP") + ": " + ip;
                        }
                    }
                    value = values.join("\n");
                }
                if (value == old_value) return;
                stdout.println("whitelist updated");
                handler.set_option("whitelist", value.replace("\n", ","));
            }, 300);
        } else if (me.id == "custom-api-url") {
            let old_url = handler.get_custom_api_url();
			let uncheckedimg;
			let selectedhopnetwork;
			let selectedcustomnetwork;
			if (old_url) {selectedhopnetwork = ".uncheckednetwork"; selectedcustomnetwork = ".checkednetwork";} else {selectedhopnetwork = ".checkednetwork"; selectedcustomnetwork = ".uncheckednetwork";}
			
            msgbox("custom", translate('Choose Network'), "<div .form> \
            <div> \
			<div #networkdefault .custom-event title='HopToDesk Network' " + selectedhopnetwork + " network='networkdefault' style=\"height: 30px; display:block;\"><div style=\"padding-top: 1px; margin-top: 5px; margin-left: 35px; display: block;\">" + translate("HopToDesk Network (Default)") + "</div></div><br></br> \
			<div #networkcustom .custom-event title='Custom Network Settings' " + selectedcustomnetwork + " network='networkcustom' id='networkcustom' style=\"height: 30px; display:block;\"><div style=\"padding-top: 1px; margin-top: 5px; margin-left: 35px; display: block;\">" + translate("Custom Network Settings") + "</div></div><br></br> \
			<span style=\"margin-top: 5px; margin-bottom: 15px;\">" + translate("Enter your custom network settings URL:") + "</span><br></br><br></br> \
			<input|text .outline-focus name='url' value='" + old_url + "' placeholder='" + translate('Custom network settings URL') + "' style=\"margin-bottom: 15px; max-width: 100%; font-size: 14px\" #customurl/></div> \
            </div> \
			", "", function(el) {
				if (el) {
					if (el.id !== 'networkcustom' && el.id !== 'networkdefault' ) {
						let resurl = $(#customurl).value;
						if (!resurl) {handler.set_custom_api_url('');return;};
								
						if (old_url != resurl) {
							let valid_url = () => {
								handler.set_custom_api_url(resurl);
							}
							if (resurl == "") return valid_url();

							httpGetRequest(resurl, #get, {}, function(data) {
								if (data.error) {
									msgbox("custom-error", translate("Custom Network Error"), translate("The custom network URL provided was not valid, please try again.") + "<br/>" + data.error, () => {});
									return;
								}

								let jsontemp = JSON.stringify(data);
								let text_res = jsontemp.toString();
								let json;
								try {
									json = JSON.parse(text_res);
								} catch (e) {
									return msgbox("custom-error", translate("Custom Network Error"), translate("The custom network URL provided was not valid, please try again.") + "<br/>" + text_res , () => {});
								}
								
								let rendezvous = data.rendezvous || data.rendezvousssl;
								if (data instanceof Object && data.turnservers && rendezvous) {
									let host = rendezvous.host;
									let port = rendezvous.port.toInteger();
									if (port == undefined || port < 0 || port > 65536) return msgbox("custom-error", translate("Custom Network Error"), "Port `" + rendezvous.port + "` is an invalid port.");
									valid_url();
								} else msgbox("custom-error", translate("Custom Network Error"), "The custom network URL provided did not return a correct response: (`" + text_res + "`).");
							}, function(err, status) {
								msgbox("custom-error", translate("Custom Network Error"), translate("The custom network URL provided was not valid, please try again.") + "<br/>Status " + status + ": `" + err + "`", () => {});
							});
						}
					} else {
						if (el && el.attributes['network'] === 'networkdefault') {
							$(#customurl).value = '';
							$(#networkdefault).attributes.addClass("checkednetwork");
							$(#networkdefault).attributes.removeClass("uncheckednetwork");
							$(#networkcustom).attributes.removeClass("checkednetwork");
							$(#networkcustom).attributes.addClass("uncheckednetwork");
						}
						if (el && el.attributes['network'] === 'networkcustom') {
							$(#customurl).state.focus = true;
							$(#networkdefault).attributes.removeClass("checkednetwork");
							$(#networkdefault).attributes.addClass("uncheckednetwork");
							$(#networkcustom).attributes.addClass("checkednetwork");
							$(#networkcustom).attributes.removeClass("uncheckednetwork");
						}
						return;
					}
                }
				
				if (!resurl) return;

            }, 240)
        } else if (me.id == "socks5-server") {
            var socks5 = handler.get_socks() || {};
            var old_proxy = socks5[0] || "";
            var old_username = socks5[1] || "";
            var old_password = socks5[2] || "";
            msgbox("custom-server", "SOCKS5 Proxy", <div .form .set-password>
            <div><span>{translate("Hostname")}:</span><input|text name='proxy' value={old_proxy} /></div>
            <div><span>{translate("Username")}:</span><input|text name='username' value={old_username} /></div>
            <div><span>{translate("Password")}:</span><PasswordComponent value={old_password} /></div>
            </div>
            , "", function(res=null) {
                if (!res) return;
				var proxy = (res.proxy || "").trim();
                var username = (res.username || "").trim();
                var password = (res.password || "").trim();
                if (proxy == old_proxy && username == old_username && password == old_password) return;
                if (proxy) {
                    var err = handler.test_if_valid_server(proxy);
                    if (err) return translate("Server") + ": " + err;
                }
                handler.set_socks(proxy, username, password);
            }, 240);
        } else if (me.id == "stop-service") {
            handler.set_option("stop-service", service_stopped ? "" : "Y");
        } else if (me.id == "allow-darktheme") {
            updateTheme();
        } else if (me.id == "tfa") {
            this.showGen2FA()
        } else if (me.id == "about") {
            this.showAbout()
        } else if (me.id == "enable-remote-printing") {
            var enable_remote_printing = handler.get_option("enable-remote-printing") == "Y" ? "N" : "Y";
            handler.set_option("enable-remote-printing", enable_remote_printing);
        } else if (me.id == "enable-wol") {
            var wasEnabled = handler.get_option("enable-wol") == "Y";
            handler.set_option("enable-wol", wasEnabled ? "N" : "Y");
            handler.set_option("wol-enabled", wasEnabled ? "" : "true");
        }
    }

    event click $(menu#config-options>li) (_, me) {
        this.handleMenuClick(me);
    }
}

var is_edit_direct_access_port;
class EditDirectAccessPort: Reactor.Component {
    function render() {
        return <span style="margin-left: 12px; padding: 0 6px; display: inline-block;" .link>{svg_edit}</span>;
    }

    function onMouse(evt) {
        if (evt.type == Event.MOUSE_DOWN) {
            is_edit_direct_access_port = true;
            editDirectAccessPort();
        }
    }
}

function editDirectAccessPort() {
    var p0 = handler.get_option('direct-access-port');
    var port = p0 ? <input|text name='port' value={p0} /> :
                    <input|text name='port' novalue={21118} />;
    msgbox("custom-direct-access-port", translate('Direct IP Access'), <div .form .set-password>
            <div><span style="width: 60px; ">{translate('Port')}:</span>{port}</div>
        </div>, "", function(res=null) {
        if (!res) return;
		var p = (res.port || '').trim();
        if (p) {
            p = p.toInteger();
            if (!(p > 0)) {
                return translate("Invalid port");
            }
            p = p + '';
        }
        if (p != p0) handler.set_option('direct-access-port', p);
      });
}

class App: Reactor.Component
{
    function this() {
        app = this;
    }

    function render() {
        var is_can_screen_recording = handler.is_can_screen_recording(false);
		var isquicksupport = handler.get_option('quicksupport') || handler.running_qs();
		
        return
            <div .app style={isquicksupport ? "width:250px" : ""}>
                    <MyIdMenu />
                    <div .top-bar>
                        <div .brand-name>HopToDesk</div>
                        {!isquicksupport && !handler.is_installed() ? <button #install-btn title={translate('install_tip')}>{translate('Install')}</button> : ""}
                        {is_osx && !is_can_screen_recording ? <button .button #mac-enable-perms title={translate('Enable Permissions')}>{translate('Enable Permissions')}</button> : ""}
                        {is_osx && is_can_screen_recording && !handler.is_process_trusted(false) ? <button .button #mac-enable-perms-acc title={translate('Enable Permissions')}>{translate('Enable Permissions')}</button> : ""}
                        <div style="width: *;" />
                        {(!isquicksupport && handler.get_option("dashboard_user_id") != "") ?
                            <svg #ticket-icon tabindex="0" title={translate("Open support tickets")} viewBox="0 0 24 24"><path fill="currentColor" d="M22 10V6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v4c1.1 0 2 .9 2 2s-.9 2-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2z"/></svg>
                            : ""
                        }
                        <ConnectStatus @{this.connect_status} />
                    </div>
                    <div .main-content>
                        <div .cards-row>
                            <div .card-device>
                                <div .card-header>{translate('This Device')}<div style="width:*;" /><svg #settings-gear tabindex="0" title={translate('Settings')} viewBox="0 0 24 24"><path fill="currentColor" d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 00.12-.61l-1.92-3.32a.49.49 0 00-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 00-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 00-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 00-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1112 8.4a3.6 3.6 0 010 7.2z"/></svg></div>
                                <div .card-body>
                                    <div .id-section>
                                        <div .id-label>{translate('Your ID')}</div>
                                        <div .id-row>
                                            {key_confirmed ? <div #idbox .idbox readonly behavior="edit" title={translate('Your unique device ID - share this with others so they can connect to you')}>{formatId(get_id())}</div> : <div #idbox .idbox readonly behavior="edit" style="font-size: 1em; color: #2D81D4;">{translate("Generating ...")}</div>}
                                            {key_confirmed ? <div #copy-id .copy-pill title={translate('Copy your device ID to clipboard so others can connect to you')}><svg viewBox="0 0 24 24"><path fill="currentColor" d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>Copy</div> : ""}
                                            {key_confirmed && !isquicksupport ? <div #invite-pill .invite-pill title={translate('Send a connection invitation to another device by entering its ID')}><svg viewBox="0 0 24 24"><path fill="currentColor" d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>Invite</div> : ""}
                                        </div>
                                    </div>
                                    <PasswordArea />
                                </div>
                            </div>
                            <div .card-remote style={isquicksupport ? "display:none" : ""}>
                                <div .card-header>{translate('Remote Control')}</div>
                                <div .card-body>
                                    <div .id-label>{translate('Partner ID')}</div>
                                    <ID @{this.remote_id} />
                                    <div .connect-buttons>
                                        <button .button #connect title={translate('Start a remote desktop session with the partner device')}>{translate('Connect')}</button>
                                        <button .button .outline #file-transfer title={translate('Open a file transfer session to send or receive files')}>{translate('Transfer File')}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div .sessions-area id="right-pane" style={isquicksupport ? "display:none" : ""}>
							<MultipleSessions @{this.multipleSessions} />
							<center><img .footer-featured src="" /></center>
                        </div>
                                                    
                        <div #launch-update style="display:none" .update_available .link url='https://www.hoptodesk.com/'>{translate('New Update Available')}</div>
                        {!is_osx && !is_can_screen_recording ? <CanScreenRecording /> : ""}
                        {!is_osx && is_can_screen_recording && !handler.is_process_trusted(false) ? <TrustMe /> : ""}
                        {!service_stopped && is_can_screen_recording && handler.is_process_trusted(false) && handler.is_installed() && !handler.is_installed_daemon(false) ? <InstallDaemon /> : ""}
                        {is_osx && !service_stopped && is_can_screen_recording && handler.is_process_trusted(false) && !handler.is_installed() && handler.is_installed_daemon(false) ? <EmptyMe />: ""}
                        {system_error ? <SystemError /> : ""}
                        {!system_error && handler.is_login_wayland() && !handler.current_is_wayland() ? <EmptyMe /> : ""}
                        {!system_error && handler.current_is_wayland() ? <EmptyMe /> : ""}
                        {is_linux && !system_error && !handler.is_login_wayland() && !handler.current_is_wayland() ? <EmptyMe />: ""}

                    </div>
                <div #overlay style="position: absolute;size:*;background:black;opacity:0.5;display:none" />
                {settingsPanelOpen ? this.renderSettingsPanel() : ""}
                {passwordSettingsOpen ? this.renderPasswordSettings() : ""}
            </div>;
    }

    function renderPasswordSettings() {
        var tempPw = password_cache[0] || handler.temporary_password() || "";
        var pwLength = handler.get_option('temporary-password-length') || '6';
        var pw = handler.permanent_password();

        return <div style="position:absolute;left:0;top:0;size:*;z-index:100;">
            <div #pw-settings-backdrop style="size:*;background:rgba(0,0,0,0.5);" />
            <div .pw-modal style="position:absolute;margin:*;">
                <div .pw-modal-header>
                    <span .pw-modal-title>{translate('Password Settings')}</span>
                    <div style="width:*;" />
                    <span .pw-modal-close>&#x2715;</span>
                </div>
                <div .pw-modal-body>
                    <div .pw-modal-section>
                        <div .pw-section-title>{translate('Permanent Password')}</div>
                        <div .pw-field-label>{translate('Password')}</div>
                        <input|password #pw-input-password .pw-input value={pw} />
                        <div .pw-field-label>{translate('Confirm')}</div>
                        <input|password #pw-input-confirm .pw-input value={pw} />
                        <div .pw-field-actions>
                            <span #pw-set-error .pw-error />
                            <div style="width:*;" />
                            <button .pw-btn .pw-btn-primary #pw-save-password>{translate('Save')}</button>
                        </div>
                    </div>

                    <div .pw-divider />

                    <div .pw-modal-section>
                        <div .pw-section-title>{translate('Random Password')}</div>
                        <div .pw-random-row>
                            <span #pw-random-display .pw-random-display>{tempPw}</span>
                            <div style="width:*;" />
                            <button .pw-btn .pw-btn-outline #pw-refresh>{translate('Refresh')}</button>
                        </div>
                        <div .pw-length-row>
                            <span .pw-field-label>{translate('Length')}:</span>
                            <div .pw-length-group>
                                <div .pw-length-btn #pw-len-6 class={pwLength == '6' ? 'selected' : ''}>6</div>
                                <div .pw-length-btn #pw-len-8 class={pwLength == '8' ? 'selected' : ''}>8</div>
                                <div .pw-length-btn #pw-len-10 class={pwLength == '10' ? 'selected' : ''}>10</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>;
    }

    // Password settings modal events
    event click $(.pw-modal-close) {
        passwordSettingsOpen = false;
        app.update();
    }
    event click $(#pw-settings-backdrop) {
        passwordSettingsOpen = false;
        app.update();
    }
    event click $(#pw-save-password) {
        var p0 = ($(#pw-input-password).value || "").trim();
        var p1 = ($(#pw-input-confirm).value || "").trim();
        var errEl = $(#pw-set-error);
        if (p0.length < 6 && p0.length != 0) {
            if (errEl) errEl.text = translate("Too short, at least 6 characters.");
            return;
        }
        if (p0 != p1) {
            if (errEl) errEl.text = translate("The confirmation is not identical.");
            return;
        }
        handler.set_permanent_password(p0);
        passwordSettingsOpen = false;
        app.update();
        passwordArea.update();
    }
    event click $(#pw-refresh) {
        handler.update_temporary_password();
        var tempPw = handler.temporary_password();
        password_cache[0] = tempPw;
        var el = $(#pw-random-display);
        if (el) el.text = tempPw;
        passwordArea.update();
    }
    event click $(#pw-len-6) { this.setTempPwLength('6'); }
    event click $(#pw-len-8) { this.setTempPwLength('8'); }
    event click $(#pw-len-10) { this.setTempPwLength('10'); }
    function setTempPwLength(len) {
        handler.set_option('temporary-password-length', len);
        handler.update_temporary_password();
        var tempPw = handler.temporary_password();
        password_cache[0] = tempPw;
        var el = $(#pw-random-display);
        if (el) el.text = tempPw;
        for (var el in $$(div.pw-length-btn)) {
            el.attributes.toggleClass("selected", el.id == "pw-len-" + len);
        }
        passwordArea.update();
    }

    function renderSettingsPanel() {
        // Auto-enable remote printing on first settings open if not explicitly set (Windows only)
        if (is_win && handler.get_option("enable-remote-printing") == "") {
            handler.set_option("enable-remote-printing", "Y");
        }
        function isEnabled(id) {
            if (id == "enable-wol") return handler.get_option(id) == "Y";
            if (id == "enable-remote-printing") return handler.get_option(id) == "Y";
            if (id == "direct-server") return handler.get_option(id) == "Y";
            return handler.get_option(id) != "N";
        }
        function toggleClass(enabled) { return enabled ? "toggle-on" : "toggle-off"; }
        function toggleBg(enabled) { return "background:" + (enabled ? "#2C8CFF" : "#CBD5E1") + ";width:36px;height:20px;border-radius:10px;position:relative;cursor:pointer;display:inline-block;"; }
        function knobStyle(enabled) { return "width:16px;height:16px;border-radius:50%;background:white;position:absolute;top:2px;left:" + (enabled ? "18px" : "2px") + ";box-shadow:0 1px 2px rgba(0,0,0,0.2);"; }
        var darkOn = handler.get_option("allow-darktheme") == "Y";
        var serviceOn = !service_stopped;
        var tfaOn = handler.has_valid_2fa();
        var langs = JSON.parse(handler.get_langs());
        var curLang = handler.get_local_option("lang") || "default";
        var curLangName = "English";
        for (var lang in langs) { if (lang[0] == curLang) { curLangName = lang[1]; break; } }
        if (curLang == "default") curLangName = "Default";

        return <div style="position:absolute;left:0;top:0;size:*;z-index:99;">
            <div #settings-backdrop style="size:*;background:rgba(0,0,0,0.3);" />
            <div #settings-panel style="position:absolute;left:0;top:0;width:280px;height:*;z-index:1;">
                <div .settings-header>
                    <span .settings-title>{translate("Settings")}</span>
                    <div style="width:*;" />
                    <span .settings-close>&#x2715;</span>
                </div>
                <div .settings-body>
                    <div .settings-section>
                        <div .section-label>{translate("Remote Access")}</div>
                        <div .setting-row id="toggle-enable-keyboard"><span .setting-name>{translate("Keyboard/Mouse")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-keyboard"))}><div .toggle-knob style={knobStyle(isEnabled("enable-keyboard"))} /></div></div>
                        <div .setting-row id="toggle-enable-clipboard"><span .setting-name>{translate("Clipboard")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-clipboard"))}><div .toggle-knob style={knobStyle(isEnabled("enable-clipboard"))} /></div></div>
                        <div .setting-row id="toggle-enable-file-transfer"><span .setting-name>{translate("File Transfer")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-file-transfer"))}><div .toggle-knob style={knobStyle(isEnabled("enable-file-transfer"))} /></div></div>
                        <div .setting-row id="toggle-enable-remote-restart"><span .setting-name>{translate("Remote Restart")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-remote-restart"))}><div .toggle-knob style={knobStyle(isEnabled("enable-remote-restart"))} /></div></div>
                        <div .setting-row id="toggle-enable-tunnel"><span .setting-name>{translate("TCP Tunneling")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-tunnel"))}><div .toggle-knob style={knobStyle(isEnabled("enable-tunnel"))} /></div></div>
                        {is_win || is_osx ? <div .setting-row id="toggle-enable-remote-printing"><span .setting-name>{translate("Remote Printing")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-remote-printing"))}><div .toggle-knob style={knobStyle(isEnabled("enable-remote-printing"))} /></div></div> : ""}
                        <div .setting-row id="toggle-enable-wol"><span .setting-name>{translate("Wake On LAN")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-wol"))}><div .toggle-knob style={knobStyle(isEnabled("enable-wol"))} /></div></div>
                    </div>
                    {handler.get_sound_inputs().length || is_win ? <div .settings-section>
                        <div .section-label>{translate("Audio Input")}</div>
                        <div .setting-row id="toggle-enable-audio"><span .setting-name>{translate("Mute")}</span><div .toggle-switch style={toggleBg(handler.get_option("enable-audio") == "N")}><div .toggle-knob style={knobStyle(handler.get_option("enable-audio") == "N")} /></div></div>
                        <div .setting-row .setting-action id="action-audio-input"><span .setting-name>{translate("Device")}</span><span .setting-value>{(function() { var v = handler.get_option("audio-input"); if (!v) v = is_win ? "System Sound" : "Default"; return v; })()}</span></div>
                    </div> : ""}
                    <div .settings-section>
                        <div .section-label>{translate("Network")}</div>
                        <div .setting-row .setting-action id="action-custom-api-url"><span .setting-name>{translate("Choose Network")}</span><span .setting-arrow>&#x203A;</span></div>
                        <div .setting-row .setting-action id="action-socks5-server"><span .setting-name>{translate("SOCKS5 Proxy")}</span><span .setting-arrow>&#x203A;</span></div>
                        <div .setting-row id="toggle-direct-server"><span .setting-name>{translate("Direct IP Access")}</span><div .toggle-switch style={toggleBg(isEnabled("direct-server"))}><div .toggle-knob style={knobStyle(isEnabled("direct-server"))} /></div></div>
                        <div .setting-row .setting-action id="action-enable-lan-discovery"><span .setting-name>{translate("LAN Discovery")}</span><div .toggle-switch style={toggleBg(isEnabled("enable-lan-discovery"))}><div .toggle-knob style={knobStyle(isEnabled("enable-lan-discovery"))} /></div></div>
                    </div>
                    <div .settings-section>
                        <div .section-label>{translate("Security")}</div>
                        <div .setting-row id="toggle-stop-service"><span .setting-name>{translate("Allow Incoming Connections")}</span><div .toggle-switch style={toggleBg(serviceOn)}><div .toggle-knob style={knobStyle(serviceOn)} /></div></div>
                        <div .setting-row .setting-action id="action-tfa"><span .setting-name>{translate("Two-Factor Authentication")}</span><span .setting-value>{tfaOn ? "On" : "Off"}</span></div>
                    </div>
                    <div .settings-section>
                        <div .section-label>{translate("Appearance")}</div>
                        <div .setting-row id="toggle-allow-darktheme"><span .setting-name>{translate("Dark Theme")}</span><div .toggle-switch style={toggleBg(darkOn)}><div .toggle-knob style={knobStyle(darkOn)} /></div></div>
                        <div .setting-row .setting-action id="action-language"><span .setting-name>{translate("Language")}</span><span .setting-value>{curLangName}</span></div>
                    </div>
                    <div .settings-section>
                        <div .section-label>{translate("Dashboard")}</div>
                        {handler.get_option("dashboard_user_id") != ""
                            ? <div .setting-row .setting-action id="action-dashboard-link"><span .setting-name>{translate("Linked")}</span><span .setting-value .dashboard-id>{handler.get_option("dashboard_user_id").substr(0, 10) + ".."}</span></div>
                            : <div .setting-row .setting-action id="action-dashboard-link"><span .setting-name>{translate("Enter Invite Code")}</span><span .setting-arrow>&#x203A;</span></div>
                        }
                    </div>
                    <div .setting-row .setting-action id="action-about" style="padding:8px 16px;"><span .setting-name>{translate("About")} {" "} {handler.get_app_name()}</span><span .setting-arrow>&#x203A;</span></div>
                </div>
            </div>
        </div>;
    }

	event click $(.idbox) {
		var el = $(#idbox);
		handler.copy_text(el.value);
	}

	event click $(#copy-id) {
		var el = $(#idbox);
		handler.copy_text(el.value);
	}

	event click $(svg#settings-gear) {
		showSettings();
	}

	event click $(menu#config-options>li) (_, me) {
		myIdMenu.handleMenuClick(me);
	}

	event click $(button#connect) {
        this.newRemote("connect");
    }

    event click $(button#install-btn) {
        handler.goto_install();
    }

    event click $(button#mac-enable-perms) {
        handler.is_can_screen_recording(true);
        watch_screen_recording();
    }

    event click $(button#mac-enable-perms-acc) {
        handler.is_process_trusted(true);
        watch_trust();
    }

    event click $(div#invite-pill) {
        showInviteDialog();
    }

    event click $(#ticket-icon) {
        if (handler.get_option("dashboard_user_id") != "") {
            handler.open_ticket_portal();
        } else {
            msgbox("custom-error", translate("Tickets"), translate("Tickets can only be created if this device is linked to a dashboard user."));
        }
    }

    function showInviteDialog() {
        msgbox("custom-invite", translate("Invite A Device"),
            "<div .form>" +
            "<div>" + translate("Input an ID to send a connection invitation for this device:") + "</div>" +
            "<input|text(remote_invite_id) style='width:*; margin-top:0.5em; margin-bottom:1em;' spellcheck='false' maxlength='10' placeholder='" + translate("Device ID to invite") + "' />" +
            "<div class='buttons' style='text-align:right; margin-top:1em;'>" +
            "</div>" +
            "</div>",
            null,
            function(res) {
                if (!res) return;
				if (res && typeof res.remote_invite_id !== 'undefined') {
                    var remote_id = (res.remote_invite_id || "").replace(/\s/g, "");
                    if (remote_id) {
                        var current_id = get_id();
                        var current_password = handler.temporary_password();
                        if (!current_password) {
                            stdout.println("Temporary password is not available, sending invite with empty password or permanent if configured.");
                        }
                        if (remote_id == current_id) {
                            msgbox("custom-error", translate("Error"), translate("Can not invite yourself."));
                            return;
                        }
						if (remote_id.length > 10 || remote_id.length < 9) {
							msgbox("custom-error", translate("Error"), translate("Please enter a valid device ID."));
							return;
						}
						if (!/^[0-9]+$/.test(remote_id)) {
							msgbox("custom-error", translate("Error"), translate("Device ID must contain only numbers (0-9)."));
							return;
						}
                        handler.send_peer_invite(remote_id, current_id, current_password);
                    }
                } else {
                    //stdout.println("Invite cancelled.");
                }
            },
            240
        );
    }

    event click $(button#file-transfer) {
        this.newRemote("file-transfer");
    }
    
    function newRemote(type) {
        createNewConnect(this.remote_id.value, type);
    }

    event click $(#launch-update) {
        handler.open_url("https://www.hoptodesk.com");
    }
}

class InstallMe: Reactor.Component {
    function render() {
        return <div .install-me style="margin-top: -4px;">
            <span />
            <div id="installtip">{translate('install_tip')}</div>
            <div><center><button #install-me .button title={translate('Install')}>{translate('Install')}</button></center></div>
        </div>;
    }

    event click $(#install-me) {
        handler.goto_install();
    }
}

class EmptyMe: Reactor.Component {
    function render() {
        return <div .empty-brand>
            <img .empty-featured src="" />
        </div>;
    }
}

function download(from, to, args..) {
    var rqp = { type:#get, url: from, toFile: to, noCache: true };
    var fn = 0;
    var on = 0;
    for( var p in args ) {
        if( p instanceof Function ) {
            switch(++fn) {
                case 1: rqp.success = p; break;
                case 2: rqp.error = p; break;
                case 3: rqp.progress = p; break;
            }
        } else if( p instanceof Object ) {
            switch(++on) {
                case 1: rqp.params = p; break;
                case 2: rqp.headers = p; break;
            }
        }
    }
    view.request(rqp);
}

