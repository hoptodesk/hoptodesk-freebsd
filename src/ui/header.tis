var pi = handler.get_default_pi(); // peer information
var chat_msgs = [];

var svg_fullscreen = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
</svg>;
var svg_action = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
</svg>;
var svg_display = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8m-4-4v4"/>
</svg>;
var svg_secure = <svg viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>;
var svg_insecure = <svg viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>;
var svg_insecure_relay = <svg viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/><circle cx="12" cy="16.5" r="1.5"/></svg>;
var svg_secure_relay = <svg viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16.5" r="1.5"/></svg>;
var svg_recording_off = <svg viewBox="0 0 24 24" fill="none" stroke="#8a8a8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>;
var svg_recording_on = <svg viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4" fill="#EF4444"/></svg>;
var svg_security_code = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>;
var svg_printer = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>;
var svg_filetransfer = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6m-3 3l3-3 3 3"/></svg>;
var svg_switchsides = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3l4 4-4 4"/><path d="M20 7H4"/><path d="M8 21l-4-4 4-4"/><path d="M4 17h16"/></svg>; 
var svg_screenshot = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>;
var svg_privacymodeoff = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" /></svg>;
var svg_privacymodeon = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828" /><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87" /><path d="M3 3l18 18" /></svg>;
var svg_monitor = <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8m-4-4v4"/></svg>;

var cur_window_state = view.windowState;
function check_state_change() {
    if (view.windowState != cur_window_state) {
        stateChanged();
    }
    self.timer(30ms, check_state_change);
}

if (is_linux) {
    check_state_change();
} else {
    view << event statechange {
        stateChanged();
    }
}

function get_id() {
    return handler.get_option('alias') || handler.get_id()
}

function stateChanged() {
    cur_window_state = view.windowState;
    adjustBorder();
    adaptDisplay();
    if (cur_window_state != View.WINDOW_MINIMIZED) {
        view.focus = handler; // to make focus away from restore/maximize button, so that enter key work
    }
    var fs = view.windowState == View.WINDOW_FULL_SCREEN;
    var el = $(#fullscreen);
    if (el) el.attributes.toggleClass("active", fs);
    el = $(#maximize);
    if (el) {
        el.state.disabled = fs;
    }
    if (fs) {
        $(header).style.set {
            display: "none",
        };
    }
}

var header;
var old_window_state = View.WINDOW_SHOWN;

var is_edit_os_password;

function editOSPassword(login=false) {
    var p0 = handler.get_option('os-password');
    msgbox("custom-os-password", 'OS Password', p0, "", function(res=null) {
        if (!res) return;
        var a0 = handler.get_option('auto-login') != '';
        var p = (res.password || '').trim();
        var a = res.autoLogin || false;
        if (p == p0 && a == a0) return;
        if (p != p0) handler.set_option('os-password', p);
        if (a != a0) handler.set_option('auto-login', a ? 'Y' : '');
        if (p && login) {
            handler.input_os_password(p, true);
        }
      });
}

var recording = false;
var privacyon = handler.get_toggle_option("privacy-mode") || false;
var portable_service_running = false;

	
class Header: Reactor.Component {
    this var conn_note = "";
    
    function this() {
        header = this;
    }

    function render() {
        var code = this.security_numbers;
        var icon_conn;
        var title_conn;
        if (code) {
            if (this.direct_connection) {
                icon_conn = svg_secure;
                title_conn = translate("Direct and encrypted connection");
            } else {
                icon_conn = svg_secure_relay;
                title_conn = translate("Relayed and encrypted connection");
            }
        } else {
            if (this.direct_connection) {
                icon_conn = svg_insecure;
                title_conn = translate("Direct and unencrypted connection");
            } else {
                icon_conn = svg_insecure_relay;
                title_conn = translate("Relayed and unencrypted connection");
            }
        }
        var title = get_id();
        if (pi.hostname) title += "(" + pi.username + "@" + pi.hostname + ")";
        if ((pi.displays || []).length == 0) {
            return <div .ellipsis style="size:*;text-align:center;margin:* 0;">{title}</div>;
        }
        var displayLabel = translate("Display") + " " + (pi.current_display + 1);
        var displayMenuItems = pi.displays.map(function(d, i) {
            return <li .display-item class={pi.current_display == i ? "selected" : ""}>
                <span>{svg_monitor}</span>{translate("Display")} {i+1}
            </li>;
        });
        updateWindowToolbarPosition();
        var style = "flow:horizontal;";
        if (is_osx) style += "margin:*";
		self.timer(1ms, updatePrivacyMode);
        self.timer(1ms, toggleMenuState);
		privacyon = handler.get_toggle_option("privacy-mode");
        var alias = handler.get_option('alias');
        var remoteIdTooltip = alias ? handler.get_id() : "";
        return <div style={style}>
            {is_osx || is_xfce ? "" : <button #fullscreen title={translate("Full Screen")}>{svg_fullscreen}</button>}
            <div #screens>
                <span #secure title={title_conn}>{icon_conn}</span>
                <div .remote-id title={remoteIdTooltip}>{get_id()}</div>
                {pi.displays.length > 1 ? <button #display-selector title={translate("Switch Display")}>{svg_monitor}<span .display-num>{pi.current_display + 1}</span><span .dropdown-arrow>&#9662;</span></button> : ""}
            </div>
            <span .toolbar-sep />
            {is_view_camera ? "" : <button #chat title={translate("Chat")}>{svg_chat}</button>}
            {is_view_camera ? "" : <button #action title={translate("Control Actions")}>{svg_action}</button>}
            <button #display title={translate("Display Settings")}>{svg_display}</button>
            {is_view_camera ? "" : <button #keyboard title={translate("Keyboard mode")}>{svg_keyboard}</button>}
            <span .toolbar-sep />
            {!is_view_camera && recording_enabled ? <button #recording title={translate("Recording")}>{recording ? svg_recording_on : svg_recording_off}</button> : ""}
            {code ? <button #securitycode title={translate("Security Code")}>{svg_security_code}</button> : ""}
			{is_view_camera ? "" : <button #transfer-file title={translate('Transfer File')}>{svg_filetransfer}</button>}
            {!is_view_camera && handler.is_remote_printing_supported() ? <button #remote-print title={translate('Remote Print')}>{svg_printer}</button> : ""}
            {handler.is_screenshot_supported() ? <button #screenshot title={translate('Screenshot')}>{svg_screenshot}</button> : ""}
			{!is_view_camera && handler.is_switchsides_supported() && (pi.platform == "Windows" || pi.platform == "Mac OS" || pi.platform == "Linux") ? <button #switch-sides style="display:block" title={translate('Switch Sides')}>{svg_switchsides}</button> : ""}
			{!is_view_camera && keyboard_enabled && (pi.platform == "Windows" || pi.platform == "Mac OS" || pi.platform == "Linux") ? <button #privacy-mode title={translate('Privacy Mode')}>{privacyon ? svg_privacymodeon : svg_privacymodeoff}</button> : ""}
            {is_view_camera ? "" : this.renderKeyboardPop()}
            {this.renderDisplayPop()}
            {is_view_camera ? "" : this.renderActionPop()}
            <menu.context #display-switch-options>{displayMenuItems}</menu>
        </div>;
    }

    function renderKeyboardPop() {
        const is_map_mode_supported = handler.is_keyboard_mode_supported("map");
        const is_translate_mode_supported = handler.is_keyboard_mode_supported("translate");
        return <menu.context #keyboard-options>
                <li #auto>{translate('Auto')}</li>
                { is_map_mode_supported && <li #map>{translate('Same layout')}</li> }
                { is_translate_mode_supported && <li #translate>{translate('Different layout')}</li> }
            </menu>;
    }

    function renderDisplayPop() {
        var codecs = handler.alternative_codecs();
        var show_codec = codecs[0] || codecs[1] || codecs[2] || codecs[3];

        var cursor_embedded = false;
        if ((pi.displays || []).length > 0) {
            if (pi.displays.length > pi.current_display) {
                cursor_embedded = pi.displays[pi.current_display].cursor_embedded;
            }
        }

        var menu = <menu.context #display-options>
                <li #adjust-window style="display:none" title={translate("Adjust Window")}>{translate('Adjust Window')}</li>
                <div #adjust-window .separator style="display:none"/>
                <li #original type="view-style" title={translate("Original")}>{translate('Original')}</li>
                <li #shrink type="view-style" title={translate("Shrink")}>{translate('Shrink')}</li>
                <li #stretch type="view-style" title={translate("Stretch")}>{translate('Stretch')}</li>
                <div .separator />
                <li #best type="image-quality" title={translate("Good image quality")}>{translate('Good image quality')}</li>
                <li #balanced type="image-quality" title={translate("Balanced")}>{translate('Balanced')}</li>
                <li #low type="image-quality" title={translate("Optimize reaction time")}>{translate('Optimize reaction time')}</li>
                <li #custom type="image-quality" title={translate("Custom")}>{translate('Custom')}</li>
                {show_codec ? <div>
                <div .separator />
                <li #auto type="codec-preference" title={translate("Auto")}>Auto</li>
                {codecs[0] ? <li #vp8 type="codec-preference">VP8 Codec</li> : ""}
                <li #vp9 type="codec-preference">VP9 Codec</li>
                {codecs[1] ? <li #av1 type="codec-preference">AV1 Codec</li> : ""}
                {codecs[2] ? <li #h264 type="codec-preference">H264 Codec</li> : ""}
                {codecs[3] ? <li #h265 type="codec-preference">H265 Codec</li> : ""}
                </div> : ""}
                <div .separator />
                {!cursor_embedded && <li #show-remote-cursor .toggle-option title={translate("Show remote cursor")}><span .toggle-track><span .toggle-knob /></span>{translate('Show remote cursor')}</li>}
                {audio_enabled ? <li #disable-audio .toggle-option title={translate("Mute")}><span .toggle-track><span .toggle-knob /></span>{translate('Mute')}</li> : ""}
                {(is_win && pi.platform == "Windows") && file_enabled ? <li #enable-file-copy-paste .toggle-option title={translate("Enable file copy and paste")}><span .toggle-track><span .toggle-knob /></span>{translate('Enable file copy and paste')}</li> : ""}
                {keyboard_enabled && clipboard_enabled ? <li #disable-clipboard .toggle-option title={translate("Disable clipboard")}><span .toggle-track><span .toggle-knob /></span>{translate('Disable clipboard')}</li> : ""}
                {keyboard_enabled ? <li #lock-after-session-end .toggle-option title={translate("Lock after session end")}><span .toggle-track><span .toggle-knob /></span>{translate('Lock after session end')}</li> : ""}
                {keyboard_enabled && ((is_osx && pi.platform != "Mac OS") || (!is_osx && pi.platform == "Mac OS")) ? <li #allow_swap_key .toggle-option title={translate("Swap control-command key")}><span .toggle-track><span .toggle-knob /></span>{translate('Swap control-command key')}</li> : ""}
                {handler.version_cmp(pi.version, '1.2.4') >= 0 ? <li #i444 .toggle-option><span .toggle-track><span .toggle-knob /></span>{translate('True color (4:4:4)')}</li> : ""}
            </menu>;
        return menu;
    }

    function renderActionPop() {
        var show_request_elevation = keyboard_enabled && pi.platform == "Windows" && !pi.sas_enabled && !portable_service_running && !is_file_transfer && !handler.is_port_forward() && !handler.is_view_camera();
        var menu = <menu.context #action-options>
                {show_request_elevation ? <li #request-elevation>{translate('Request Elevation')}</li> : ""}
                {keyboard_enabled ? <li #os-password>{translate('OS Password')}</li> : ""}
                <li #tunnel>{translate('TCP Tunneling')}</li>
                <div .separator />
                {keyboard_enabled && (pi.platform == "Linux" || (pi.platform == "Windows" && pi.sas_enabled)) ? <li #ctrl-alt-del>{translate('Insert')} Ctrl + Alt + Del</li> : ""}
                {restart_enabled && (pi.platform == "Linux" || pi.platform == "Windows" || pi.platform == "Mac OS") ? <li #restart_remote_device>{translate('Restart Remote Device')}</li> : ""}
                {keyboard_enabled ? <li #lock-screen>{translate('Insert Lock')}</li> : ""}
                {keyboard_enabled && pi.platform == "Windows" && pi.sas_enabled ? <li #block-input>{translate("Block user input")}</li> : ""}
                <li #note>{translate('Note')}</li>
                <li #refresh>{translate('Refresh')}</li>
            </menu>;
        return menu;
    }

    function renderGlobalScreens() {
        if (pi.displays.length < 3) return "";
        var x0 = 9999999;
        var y0 = 9999999;
        var x = -9999999;
        var y = -9999999;
        pi.displays.map(function(d, i) {
            if (d.x < x0) x0 = d.x;
            if (d.y < y0) y0 = d.y;
            var dx = d.x + d.width;
            if (dx > x) x = dx;
            var dy = d.y + d.height;
            if (dy > y) y = dy;
        });
        var w = x - x0;
        var h = y - y0;
        var scale = 16. / h;
        var screens = pi.displays.map(function(d, i) {
            var min_wh = d.width > d.height ? d.height : d.width;
            var fs = min_wh * 0.9 * scale;
            var style = "width:" + (d.width * scale) + "px;" +
                        "height:" + (d.height * scale) + "px;" +
                        "left:" + ((d.x - x0) * scale) + "px;" +
                        "top:" + ((d.y - y0) * scale) + "px;" +
                        "font-size:" + fs + "px;";
            if (is_osx) {
              style += "line-height:" + fs + "px;";
            }
            return <div style={style} class={pi.current_display == i ? "current" : ""}>{i+1}</div>;
        });

        var style = "width:" + (w * scale) + "px; height:" + (h * scale) + "px;";
        return <div #global-screens style={style}>
            {screens}
        </div>;
    }

    event click $(#fullscreen) (_, el) {
        if (view.windowState == View.WINDOW_FULL_SCREEN) {
            if (old_window_state == View.WINDOW_MAXIMIZED) {
                view.windowState = View.WINDOW_SHOWN;
            }
            view.windowState = old_window_state;
        } else {
            old_window_state = view.windowState;
            if (view.windowState == View.WINDOW_MAXIMIZED) {
                view.windowState = View.WINDOW_SHOWN;
            }
            view.windowState = View.WINDOW_FULL_SCREEN;
            if (is_linux) { self.timer(150ms, function() { view.windowState = View.WINDOW_FULL_SCREEN; }); }
        }
    }
    
    event click $(#chat) {
        startChat();
    }
    
    event click $(#securitycode) {
        var code = this.security_numbers;
        msgbox("nocancel", translate("Your Security Code"), generate_security_number_block(code), "", function() { });
    }
    
    event click $(#action) (_, me) {
        var menu = $(menu#action-options);
        showPopupMenu(me, menu);
    }

    event click $(#display) (_, me) {
        var menu = $(menu#display-options);
        showPopupMenu(me, menu);
    }

    event click $(#keyboard) (_, me) {
        var menu = $(menu#keyboard-options);
        showPopupMenu(me, menu);
    }

    event click $(#recording) (_, me) {
        header.update();
        handler.record_screen(!recording)
    }

    event click $(#privacy-mode) (_, me) {
		togglePrivacyMode(me.id);
    }

    event click $(#screen) (_, me) {
        if (pi.current_display == me.index) return;
        handler.switch_display(me.index);
    }

    event click $(#display-selector) (_, me) {
        var menu = $(menu#display-switch-options);
        showPopupMenu(me, menu);
    }

    event keyup (evt) {
        if((pi.displays || []).length > 0 && evt.keyCode == 220)
        {
            if (pi.displays.length > pi.current_display)
                handler.switch_display(pi.current_display + 1);
            else
                handler.switch_display(1);
        }
        if (evt.ctrlKey && evt.keyCode == 80) {
            showPrinterDialog();
        }
    }

    event keydown (evt) {
        if (evt.ctrlKey && evt.shiftKey) {
            switch (evt.keyCode) {
                case 0x53: // Ctrl+Shift+S = Screenshot
                    if (handler.is_screenshot_supported()) {
                        screenshot_auto_clipboard = true;
                        handler.take_screenshot(pi.current_display, "");
                    }
                    return true;
                case 0x52: // Ctrl+Shift+R = Toggle Recording
                    if (!is_view_camera && recording_enabled) {
                        handler.record_screen(!recording);
                        header.update();
                    }
                    return true;
                case 0x54: // Ctrl+Shift+T = File Transfer
                    if (!is_view_camera) handler.transfer_file();
                    return true;
                case 0x46: // Ctrl+Shift+F = Toggle Fullscreen
                    handler.toggle_option("fullscreen");
                    return true;
            }
        }
    }

    event click $(#transfer-file) {
        handler.transfer_file();
    }
    
    event click $(#remote-print) {
        showPrinterDialog();
    }
    
    event click $(#switch-sides) {
        msgbox(
            "Switch sides confirmation",
            translate("Switch sides"),
            translate("Are you sure you want to switch sides") + "?",
            "",
            function(res=null) {
                if (res != null) {
                    handler.switch_sides_handler();
                    view.close();
                }
            }
        );
    }

    event click $(#screenshot) {
        screenshot_auto_clipboard = true;
        handler.take_screenshot(pi.current_display, "");
    }

    event click $(#request-elevation) {
        msgbox("custom-elevation", translate('Request Elevation'),
            <div .form>
                <div style="margin-bottom: 12px;">
                    {translate('Ask the remote user for authentication')}
                    <div style="font-size: 0.85em; color: #888; margin-top: 4px;">{translate('Choose this if the remote account is administrator')}</div>
                </div>
                <div style="margin-bottom: 8px;">
                    <button|checkbox(use_logon) #elevation-use-logon .custom-event>{translate('Transmit the username and password of administrator')}</button>
                </div>
                <div #elevation-logon-fields style="display: none;">
                    <div style="margin-bottom: 8px; padding: 6px 8px; background: #f0f0f0; border: 1px solid #ccc; border-radius: 4px; font-size: 0.85em;">
                        {translate('still_click_uac_tip')}
                    </div>
                    <div style="margin-bottom: 4px;">{translate('Username')}</div>
                    <input|text(username) .outline-focus placeholder={translate('eg: admin')} style="width: *; margin-bottom: 8px;" />
                    <div style="margin-bottom: 4px;">{translate('Password')}</div>
                    <input|password(password) style="width: *;" />
                </div>
            </div>,
            "", function(res=null) {
                if (!res) return;
                if (res.id === "elevation-use-logon") {
                    var fields = $(#elevation-logon-fields);
                    if (fields) {
                        fields.style.set { display: res.checked ? "block" : "none" };
                    }
                    return;
                }
                if (res.use_logon) {
                    var u = (res.username || "").trim();
                    var p = (res.password || "").trim();
                    if (!u) return translate('Empty Username');
                    if (!p) return translate('Empty Password');
                    handler.elevate_with_logon(u, p);
                } else {
                    handler.elevate_direct();
                }
            }, 360);
    }

    event click $(#os-password) (evt) {
        if (is_edit_os_password) {
            is_edit_os_password = false;
            return;
        }
        var p = handler.get_option('os-password');
        if (!p) editOSPassword(true);
        else handler.input_os_password(p, true);
    }

    event click $(#tunnel) {
        handler.tunnel();
    }

    event click $(#note) {
        var self = this;
        msgbox("custom", "Note", <div .form>
         <textarea .outline-focus spellcheck="false" name="text" novalue="input note here" style="overflow: scroll-indicator; width:*; height: 140px; font-size: 1.2em; padding: 0.5em;">{self.conn_note}</textarea>
          </div>, "", function(res=null) {
            if (!res) return;
            if (res.text == null || res.text == undefined) return;
            self.conn_note = res.text ?? "";
            handler.send_note(res.text);
          }, 280);
    }

    event click $(#ctrl-alt-del) {
        handler.ctrl_alt_del();
    }

    event click $(#restart_remote_device) {
        msgbox(
            "restart-confirmation",
            translate("Restart remote device"),
            translate("Are you sure you want to restart") + " " + pi.username + "@" + pi.hostname + "(" + get_id() + ") ?",
            "",
            function(res=null) {
                if (res != null) handler.restart_remote_device();
            }
        );
    }

    event click $(#lock-screen) {
        handler.lock_screen();
    }

    event click $(#refresh) {
        handler.refresh_video(0);
    }

    event click $(#block-input) {
        if (!input_blocked) {
            handler.toggle_option("block-input");
            input_blocked = true;
            $(#block-input).text = translate("Unblock user input");
        } else {
            handler.toggle_option("unblock-input");
            input_blocked = false;
            $(#block-input).text = translate("Block user input");
        }
    }

    event click $(menu#display-options li) (_, me) {
        if (me.id == "custom") {
            handle_custom_image_quality();
        } else if (me.id == "privacy-mode") {
            togglePrivacyMode(me.id);
        } else if (me.id == "show-quality-monitor") {
            toggleQualityMonitor(me.id);
        } else if (me.id == "i444") {
            toggleI444(me.id);
        } else if (me.attributes.hasClass("toggle-option")) {
            handler.toggle_option(me.id);
            toggleMenuState();
        } else if (!me.attributes.hasClass("selected")) {
            var type =  me.attributes["type"];
            if (type == "image-quality") {
                handler.save_image_quality(me.id);
            } else if (type == "view-style") {
                handler.save_view_style(me.id);
                adaptDisplay();
            } else if (type == "codec-preference") {
                handler.set_option("codec-preference", me.id);
                handler.change_prefer_codec();
            }
            toggleMenuState();
        }
    }

    event click $(menu#keyboard-options>li) (_, me) {
        handler.save_keyboard_mode(me.id);
        toggleMenuState();
    }

    event click $(menu#display-switch-options li) (_, me) {
        var idx = me.index;
        if (pi.current_display == idx) return;
        handler.switch_display(idx);
    }
}

function showPrinterDialog() {
    var defaultPrinter = "";
    try { defaultPrinter = handler.get_default_printer(); } catch(e) {}
    var printers = [];
    try { printers = handler.get_printer_names(); } catch(e) {}
    if (printers.length == 0) {
        msgbox("nocancel", translate("Remote Print"),
            translate("No printers found on this computer."), "", null);
        return;
    }
    msgbox("select-printer", translate("Remote Print"),
        "", "", function(res=null) {
            if (!res) return;
            var name = res.printer || defaultPrinter;
            if (name) {
                handler.set_option("printer-selected-name", name);
                if (res.always_use_printer) {
                    handler.set_option("always-use-printer", "Y");
                }
                msgbox("nocancel", translate("Remote Print"),
                    "Printer set to: " + name, "", function() {});
            }
        }, 240);
}

function handle_custom_image_quality() {
    var tmp = handler.get_custom_image_quality();
    var bitrate = (tmp[0] || 50);
    var extendedBitrate = bitrate > 100;
    var maxRate = extendedBitrate ? 2000 : 100;
    msgbox("custom-image-quality", "Custom Image Quality", "<div .form> \
          <div><input #bitrate-slider type=\"hslider\" style=\"width: 50%\" name=\"bitrate\" max=\"" + maxRate + "\" min=\"10\" value=\"" + bitrate + "\"/ buddy=\"bitrate-buddy\"><b #bitrate-buddy>x</b>% Bitrate <button|checkbox #extended-slider .custom-event " + (extendedBitrate ? "checked" : "") + ">More</button></div> \
      </div>", "", function(res=null) {
        if (!res) return;
        if (res.id === "extended-slider") {
            var slider = res.parent.$(#bitrate-slider)
            slider.slider.max = res.checked ? 2000 : 100;
            if (slider.value > slider.slider.max) {
                slider.value = slider.slider.max;
            }
            var buddy = res.parent.$(#bitrate-buddy);
            buddy.value = slider.value;
            return;
        }
        if (!res.bitrate) return;
        handler.save_custom_image_quality(res.bitrate);
        toggleMenuState();
      });
}

function toggleMenuState() {
    var values = [];
    var q = handler.get_image_quality();
    if (!q) q = "balanced";
    values.push(q);
    var s = handler.get_view_style();
    if (!s) {
        s = "shrink";
        handler.save_view_style(s);
        adaptDisplay();
    }
    values.push(s);
    var c = handler.get_option("codec-preference");
    if (!c) c = "auto";
    values.push(c);
    for (var el in $$(menu#display-options li)) {
        var want = values.indexOf(el.id) >= 0;
        if (el.attributes.hasClass("selected") != want)
            el.attributes.toggleClass("selected", want);
    }
    var k = handler.get_raw_keyboard_mode();
    for (var el in $$(menu#keyboard-options>li)) {
        var want = (el.id == k);
        if (el.attributes.hasClass("selected") != want)
            el.attributes.toggleClass("selected", want);
    }
    for (var id in ["show-remote-cursor", "follow-remote-cursor", "follow-remote-window", "show-quality-monitor", "disable-audio", "enable-file-copy-paste", "disable-clipboard", "lock-after-session-end", "allow_swap_key", "i444"]) {
        var el = self.select('#' + id);
        if (el) {
            var value = handler.get_toggle_option(id);
            if (el.attributes.hasClass("selected") != value)
                el.attributes.toggleClass("selected", value);
        }
    }
}

if (is_osx) {
    $(header).content(<Header />);
    $(header).attributes["role"] = "window-caption";
} else {
    if (is_file_transfer || is_port_forward) {
        $(caption).content(<Header />);
    } else {
        $(div.window-toolbar).content(<Header />);
    }
    setWindowButontsAndIcon();
}

// Re-center toolbar after Reactor re-renders
var _origHeaderUpdate = header.update;
header.update = function() {
    _origHeaderUpdate.call(header);
    updateWindowToolbarPosition();
};

if (!(is_file_transfer || is_port_forward)) {
    $(header).style.set {
        height: "32px",
    };
    if (!is_osx) {
        $(div.window-icon).style.set {
            size: "32px",
        };
    }
}


// MCP commands: check for dismiss, click_button, chat, password, and query_state via stdin pipe
function checkMcpCommands() {
    try {
        if (handler.check_mcp_dismiss()) {
            closeMsgbox();
        }
        var btnId = handler.get_mcp_click_button();
        if (btnId) {
            clickToolbarButton(btnId);
        }
        var chatMsg = handler.get_mcp_chat_msg();
        if (chatMsg) {
            handler.send_chat(chatMsg);
        }
        var pw = handler.get_mcp_password();
        if (pw) {
            handler.login("", "", pw, false);
            closeMsgbox();
            msgbox("connecting", "Connecting...", "Logging in...");
        }
        if (handler.check_mcp_query_state()) {
            gatherAndWriteMcpState();
        }
    } catch(e) {}
    self.timer(300ms, checkMcpCommands);
}
self.timer(300ms, checkMcpCommands);

// Gather full UI state and write to temp file for parent process
function gatherAndWriteMcpState() {
    try {
        var peerId = handler.get_id();

        // Connection quality from qualityMonitorData (updated by updateQualityStatus)
        var quality = {
            speed: qualityMonitorData[0] || null,
            fps: qualityMonitorData[1] || null,
            delay_ms: qualityMonitorData[2] || null,
            target_bitrate_kb: qualityMonitorData[3] || null,
            codec: qualityMonitorData[4] || null,
        };

        // Display info from peer info
        var displays = [];
        if (pi && pi.displays) {
            for (var i = 0; i < pi.displays.length; i++) {
                var d = pi.displays[i];
                displays.push({
                    index: i,
                    width: d.width,
                    height: d.height,
                    x: d.x,
                    y: d.y,
                    cursor_embedded: d.cursor_embedded || false,
                });
            }
        }

        // Dialog/popup state
        var dialogVisible = false;
        var dialogType = "";
        var msgboxEl = $(div.msgbox);
        if (msgboxEl && msgboxEl.style["display"] != "none") {
            dialogVisible = true;
            dialogType = last_msgbox_tag || "unknown";
        }
        var popupOpen = _activePopup ? true : false;

        // Settings
        var viewStyle = handler.get_view_style();
        var imageQuality = handler.get_image_quality();
        var codecPref = handler.get_option("codec-preference");
        var keyboardMode = handler.get_raw_keyboard_mode();

        // Connection type
        var isSecure = header ? (header.secure_connection || false) : false;
        var isDirect = header ? (header.direct_connection || false) : false;

        // Window state
        var winState = "normal";
        if (view.windowState == View.WINDOW_FULL_SCREEN) winState = "fullscreen";
        else if (view.windowState == View.WINDOW_MINIMIZED) winState = "minimized";

        var state = {
            peer_id: peerId,
            platform: pi ? pi.platform : "unknown",
            hostname: pi ? pi.hostname : "",
            username: pi ? pi.username : "",
            version: pi ? pi.version : "",
            current_display: pi ? pi.current_display : 0,
            displays: displays,
            connection: {
                secure: isSecure,
                direct: isDirect,
                quality: quality,
            },
            permissions: {
                keyboard: keyboard_enabled,
                clipboard: clipboard_enabled,
                audio: audio_enabled,
                file_transfer: file_enabled,
                restart: restart_enabled,
                recording: recording_enabled,
            },
            ui: {
                window_state: winState,
                recording: recording,
                privacy_mode: privacyon,
                dialog_open: dialogVisible,
                dialog_type: dialogType,
                popup_open: popupOpen,
                view_style: viewStyle,
                image_quality: imageQuality,
                codec_preference: codecPref,
                keyboard_mode: keyboardMode,
            },
            toolbar: (function() {
                try {
                    var hdr = $(header);
                    if (!hdr) return null;
                    var toolbar = $(div.window-toolbar) || hdr.$(div);
                    if (!toolbar) return null;
                    var tw = toolbar.box(#width, #border);
                    var hw = hdr.box(#width, #border);
                    var tl = toolbar.box(#left, #border, #parent);
                    var centered = hw > 0 && tw > 0 ? Math.abs(tl - (hw - tw) / 2) < 5 : null;
                    // Collect visible buttons
                    var btns = [];
                    for (var el in toolbar.$$(button[id])) {
                        if (el.style["display"] != "none") btns.push(el.attributes["id"]);
                    }
                    return { width: tw, header_width: hw, left: tl, centered: centered, buttons: btns };
                } catch(e) { return null; }
            })(),
            video: {
                width: display_width,
                height: display_height,
                scale: display_scale,
                cursor_embedded: display_cursor_embedded,
            },
        };

        handler.write_mcp_state(peerId, JSON.stringify(state));
    } catch(e) {
        handler.write_mcp_state(handler.get_id() || "unknown", JSON.stringify({error: "" + e}));
    }
}

// Programmatically click a toolbar button or submenu item by ID
// Supports "button_id" for top-level buttons and "menu:item_id" for submenu items
function clickToolbarButton(btnId) {
    // Handle submenu items: "display:shrink", "action:ctrl-alt-del", "keyboard:map"
    var colonIdx = btnId.indexOf(":");
    if (colonIdx > 0) {
        var menuId = btnId.substr(0, colonIdx);
        var itemId = btnId.substr(colonIdx + 1);
        clickSubmenuItem(menuId, itemId);
        return;
    }
    stdout.println("MCP: clicking button '" + btnId + "'");
    // Dispatch known actions directly (no DOM element needed)
    if (btnId == "screenshot") { screenshot_auto_clipboard = true; handler.take_screenshot(pi.current_display, ""); return; }
    if (btnId == "chat") { startChat(); return; }
    if (btnId == "transfer-file") { handler.transfer_file(); return; }
    if (btnId == "remote-print") { showPrinterDialog(); return; }
    if (btnId == "recording") { header.update(); handler.record_screen(!recording); return; }
    // Actions that need the toolbar element for popup menus or fallback click
    var toolbar = $(div.window-toolbar) || $(header);
    if (!toolbar) { stdout.println("MCP: no toolbar element found"); return; }
    var el = toolbar.$(button#{btnId});
    if (!el) el = toolbar.$(div#{btnId});
    if (!el) { stdout.println("MCP: button '" + btnId + "' not found in toolbar"); return; }
    if (btnId == "action") { showPopupMenu(el, $(menu#action-options)); }
    else if (btnId == "display") { showPopupMenu(el, $(menu#display-options)); }
    else if (btnId == "keyboard") { showPopupMenu(el, $(menu#keyboard-options)); }
    else if (btnId == "privacy-mode") { togglePrivacyMode(btnId); }
    else { el.sendEvent("click"); }
}

// Execute a submenu item action directly without opening the popup
function clickSubmenuItem(menuId, itemId) {
    if (menuId == "action") {
        // Action menu items - each has its own click handler
        if (itemId == "request-elevation") { handler.elevate_direct(); }
        else if (itemId == "os-password") {
            var p = handler.get_option("os-password");
            if (!p) editOSPassword(true);
            else handler.input_os_password(p, true);
        }
        else if (itemId == "tunnel") { handler.tunnel(); }
        else if (itemId == "ctrl-alt-del") { handler.ctrl_alt_del(); }
        else if (itemId == "restart_remote_device") { handler.restart_remote_device(); }
        else if (itemId == "lock-screen") { handler.lock_screen(); }
        else if (itemId == "block-input") {
            if (!input_blocked) {
                handler.toggle_option("block-input");
                input_blocked = true;
            } else {
                handler.toggle_option("unblock-input");
                input_blocked = false;
            }
        }
        else if (itemId == "refresh") { handler.refresh_video(0); }
        // unknown action items are silently ignored (validated by MCP server)
    }
    else if (menuId == "display") {
        // Display menu items
        if (itemId == "custom") { handle_custom_image_quality(); }
        else if (itemId == "privacy-mode") { togglePrivacyMode(itemId); }
        else if (itemId == "show-quality-monitor") { toggleQualityMonitor(itemId); }
        else if (itemId == "show-remote-cursor" || itemId == "disable-audio" ||
                 itemId == "disable-clipboard" || itemId == "lock-after-session-end") {
            handler.toggle_option(itemId);
            toggleMenuState();
        }
        else if (itemId == "original" || itemId == "shrink" || itemId == "stretch" || itemId == "adaptive") {
            handler.save_view_style(itemId);
            adaptDisplay();
            toggleMenuState();
        }
        else if (itemId == "best" || itemId == "balanced" || itemId == "low") {
            handler.save_image_quality(itemId);
            toggleMenuState();
        }
        // unknown display items are silently ignored (validated by MCP server)
    }
    else if (menuId == "keyboard") {
        if (itemId == "auto" || itemId == "map" || itemId == "translate") {
            handler.save_keyboard_mode(itemId);
            toggleMenuState();
        }
    }
    // unknown menus are silently ignored (validated by MCP server)
}

handler.updatePi = function(v) {
    pi = v;
    recording = handler.is_recording();
    header.update();
    if (is_port_forward) {
        view.windowState = View.WINDOW_MINIMIZED;
    }
}

handler.updateDisplays = function(v) {
    pi.displays = v;
    header.update();
    if (is_port_forward) {
        view.windowState = View.WINDOW_MINIMIZED;
    }
}

handler.setMultipleWindowsSession = function(sessions) {
    // It will be covered by other message box if the timer is not used, 
    self.timer(1000ms, function() {
        msgbox("multiple-sessions-nocancel", translate("Multiple Windows sessions found"), <MultipleSessionComponent sessions={sessions} />, "", function(res) {
            if (res && res.sid) {
                handler.set_selected_windows_session_id("" + res.sid);
            }
        }, 230);
    });
}

handler.setCurrentDisplay = function(v) {
    pi.current_display = v;
    handler.switch_display(v);
    header.update();
    if (is_port_forward) {
        view.windowState = View.WINDOW_MINIMIZED;
    }
}

handler.screenshot = function(msg) {
    if (screenshot_auto_clipboard) {
        screenshot_auto_clipboard = false;
        if (!msg) {
            handler.handle_screenshot("1");
            // Flash icon green and show toast above toolbar
            var btn = $(button#screenshot);
            if (btn) {
                btn.style.set { color: "#28A745" };
                // Create floating toast
                var existing = $(div#screenshot-toast);
                if (existing) existing.remove();
                var toast = new Element("div");
                toast.attributes["id"] = "screenshot-toast";
                toast.attributes["class"] = "screenshot-toast";
                toast.text = translate("Screenshot saved to clipboard");
                var toolbar = $(div#toolbar) || btn.parent;
                if (toolbar) toolbar.insert(toast);
                self.timer(2500ms, function() {
                    btn.style.set { color: undefined };
                    var t = $(div#screenshot-toast);
                    if (t) t.remove();
                });
            }
        }
        return;
    }
    if (msg) {
        msgbox(
            "custom-nocancel-nook-hasclose-error",
            translate("Take screenshot"),
            msg,
            "",
            function() {}
        );
    } else {
        msgbox(
            "custom-take-screenshot-nocancel-nook",
            translate("Take screenshot"),
            translate("screenshot-action-tip"),
            "",
            function() {}
        );
    }
}

function updatePrivacyMode() {
	var el = $(button#privacy-mode);
    if (el) {
        var supported = handler.is_privacy_mode_supported();
        if (!supported) {
            el.style["display"]="none";
        } else {
            el.style["display"]="block";
            var value = handler.get_toggle_option("privacy-mode");
            if (privacyon != value) {
                privacyon = value;
                header.update();
            }
            var bi = $(li#block-input);
            if (bi) {
                bi.state.disabled = value;
            }
        }
    }
}
handler.updatePrivacyMode = updatePrivacyMode;

function togglePrivacyMode(privacy_id) {
    var supported = handler.is_privacy_mode_supported();
    if (!supported) {
        msgbox("nocancel", translate("Privacy mode"), translate("Unsupported"), "", function() { });
    } else {
        handler.toggle_option(privacy_id);
    }
}

function toggleQualityMonitor(name) {
    var show = handler.get_toggle_option(name);
    if (show) {
        $(#quality-monitor).style.set{ display: "none" };
    } else {
        $(#quality-monitor).style.set{ display: "block" };
    }
    handler.toggle_option(name);
    toggleMenuState();
}

function toggleI444(name) {
    handler.toggle_option(name);
    handler.update_supported_decodings();
    toggleMenuState();
}

handler.updateBlockInputState = function(input_blocked) {
    if (!input_blocked) {
        handler.toggle_option("block-input");
        input_blocked = true;
        $(#block-input).text = translate("Unblock user input");
    } else {
        handler.toggle_option("unblock-input");
        input_blocked = false;
        $(#block-input).text = translate("Block user input");
    }
}

handler.switchDisplay = function(i) {
    pi.current_display = i;
    header.update();
}

function updateWindowToolbarPosition() {
    if (is_osx) return;
    self.timer(1ms, function() {
        var el = $(div.window-toolbar);
        var w1 = el.box(#width, #border);
        var w2 = $(header).box(#width, #border);
        var x = (w2 - w1) / 2;
        el.style.set {
            left: x + "px",
            display: "block",
        };
    });
}

view.on("size", function() {
    // ensure size is done, so add timer
    self.timer(1ms, function() {
        updateWindowToolbarPosition();
        adaptDisplay();
    });
});

handler.newMessage = function(text) {
    chat_msgs.push({text: text, name: pi.username || "", time: getNowStr()});
    startChat();
}

function sendMsg(text) {
    chat_msgs.push({text: text, name: "me", time: getNowStr()});
    handler.send_chat(text);
    if (chatbox) chatbox.refresh();
}

var chatbox;
function startChat() {
    if (chatbox) {
        chatbox.windowState = View.WINDOW_SHOWN;
        chatbox.refresh();
        return;
    }
    var icon = handler.get_icon();
    var (sx, sy, sw, sh) = view.screenBox(#workarea, #rectw);
    var w = scaleIt(300);
    var h = scaleIt(400);
    var x = (sx + sw - w) / 2;
    var y = sy + scaleIt(80);
    var params = {
        type: View.FRAME_WINDOW,
        x: x,
        y: y,
        width: w,
        height: h,
        client: true,
        parameters: { msgs: chat_msgs, callback: sendMsg, icon: icon },
        caption: get_id(),
    };
    var html = handler.get_chatbox();
    if (html) params.html = html;
    else params.url = self.url("chatbox.html");
    chatbox = view.window(params);
}

var _base_msgbox_retry = handler.msgbox_retry;
handler.msgbox_retry = function(type, title, text, link, hasRetry) {
    if (type == "error" && !hasRetry && chatbox) {
        chatbox.windowState = View.WINDOW_HIDDEN;
    }
    _base_msgbox_retry(type, title, text, link, hasRetry);
}

handler.setConnectionType = function(secured, direct, security_numbers, avatar_image) {
    header.secure_connection = secured;
    header.direct_connection = direct;
    header.security_numbers = security_numbers;
    header.avatar_image = avatar_image;
    header.update();
}

handler.updateRecordStatus = function(status) {
    recording = status;
    header.update();
}

handler.portableServiceRunning = function(running) {
    portable_service_running = running;
    header.update();
}
